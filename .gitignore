# .gitignore for Python Flask Project

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/

# Virtual environment directories
venv/
.venv/
env/
env.bak/
pyvenv.cfg

# Environment variables and configuration files
.env
.env.*
.envrc

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*.log

# OS generated files
.DS_Store
Thumbs.db

# Flask specific
instance/
webassets-cache/
*.db  # e.g., SQLite databases
config.py  # If you have a local config file

# Project-specific files
app/logs/  # If you have logs in this directory
secrets.py  # Any files with sensitive data
devices.yaml  # If you don't want to track this
commands.yaml  # If you don't want to track this

# Dependency files
Pipfile.lock

# Temporary files
*.tmp
*.bak

# Gunicorn and server logs
gunicorn.log
error.log
